<html>
  <head>
    <meta charset='utf-8' />
    <title>Payment Reminder</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f9f9f9;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        background: #ffffff;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
        padding: 20px;
      }
      h2 {
        color: #333333;
        margin-bottom: 10px;
      }
      .details {
        margin: 20px 0;
        border-collapse: collapse;
        width: 100%;
      }
      .details th,
      .details td {
        border: 1px solid #dddddd;
        padding: 10px;
        text-align: left;
      }
      .details th {
        background-color: #f0f0f0;
      }
      .footer {
        margin-top: 30px;
        font-size: 12px;
        color: #777777;
        text-align: center;
      }
      .btn {
        display: inline-block;
        background-color: #4caf50;
        color: white;
        padding: 10px 18px;
        text-decoration: none;
        border-radius: 4px;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <h2>Reminder: Upcoming Bill Payment</h2>
      <p>Hello {{name}},</p>
      <p>This is a friendly reminder that you have a bill coming due soon.
        Please review the details below:</p>

      <table class='details'>
        <tr>
          <th>Description</th>
          <td>{{bill.description}}</td>
        </tr>
        <tr>
          <th>Amount</th>
          <td>{{bill.amount}}</td>
        </tr>
        <tr>
          <th>Due Date</th>
          <td>{{bill.dueDate}}</td>
        </tr>
      </table>

      <div class='footer'>
        <p>Thank you for using Remindly. Stay on top of your bills effortlessly!</p>
      </div>
    </div>
  </body>
</html>